---
// SVG icons inline
const ZapIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`;

const DatabaseIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`;

const CheckCircle2Icon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>`;

const ServerIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>`;

const TerminalIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>`;

const deliverables = [
  {
    icon: ZapIcon,
    title: "Speed to Lead",
    desc: "Automação que chama o lead no WhatsApp em < 60 segundos. O lead pensa que é mágica. Nós sabemos que é API."
  },
  {
    icon: DatabaseIcon,
    title: "Reativação de Base",
    desc: "Pegamos os leads 'mortos' dos meses anteriores e esprememos dinheiro deles via campanhas de reengajamento automatizadas."
  },
  {
    icon: CheckCircle2Icon,
    title: "Qualificação via IA",
    desc: "O vendedor do seu cliente só recebe o lead pronto para passar o cartão. O 'lixo' é filtrado antes de chegar no humano."
  },
  {
    icon: ServerIcon,
    title: "Infraestrutura Própria",
    desc: "VPS Dedicada, Portainer, n8n self-hosted, Evolution API. Sem 'gambiarras' no Zapier que quebram no fim de semana."
  }
];
---

<section class="py-24 bg-[#0a0a0a] relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-yellow-500/5 -skew-x-12 transform origin-top-right pointer-events-none"></div>

  <div class="container mx-auto px-6 max-w-6xl relative z-10">
    <div class="flex flex-col md:flex-row gap-16 items-start">
      
      <!-- Header Area -->
      <div class="md:w-1/3 sticky top-24">
        <div class="inline-flex items-center gap-2 text-yellow-500 font-mono text-sm mb-4">
           <div class="w-4 h-4" set:html={TerminalIcon} />
           <span>SYSTEM_READY</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold font-industrial text-white mb-6 leading-none uppercase">
          Eu sou o seu braço de <span class="text-yellow-500">Tecnologia</span> e Operações.
        </h2>
        <p class="text-gray-400 text-lg leading-relaxed mb-8">
          Pare de tentar ensinar seu gestor de tráfego a configurar webhooks. Eu entro como um parceiro técnico invisível (White Label) ou estratégico.
        </p>
        <div class="h-1 w-24 bg-yellow-500"></div>
      </div>

      <!-- Grid Area -->
      <div class="md:w-2/3 grid gap-6">
        {deliverables.map((item, index) => (
          <div key={index} class="flex items-start gap-6 bg-[#111] p-6 border border-gray-800 hover:border-yellow-500/50 transition-all duration-300 group">
            <div class="shrink-0 p-3 bg-black border border-gray-700 group-hover:border-yellow-500 transition-colors">
              <div class="w-6 h-6 text-yellow-400" set:html={item.icon} />
            </div>
            <div>
              <h3 class="text-xl font-bold text-white mb-2 font-industrial uppercase">{item.title}</h3>
              <p class="text-gray-400 leading-relaxed text-sm md:text-base">
                {item.desc}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

