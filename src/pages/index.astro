    <div class="max-w-2xl mx-auto relative z-10">
      <div class="text-center mb-12">
        <span class="inline-flex items-center gap-2 text-yellow-500 font-mono text-sm mb-4">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
          Contato
        </span>
        <h2 class="text-3xl md:text-5xl font-bold font-industrial text-white uppercase tracking-tight mb-4 leading-none">
          Vamos conversar.
        </h2>
        <p class="text-gray-400 text-base md:text-lg">
          Conta o que você precisa. Te respondo no WhatsApp em breve.
        </p>
      </div>

      <div class="bg-[#111] border border-gray-800 p-8 md:p-10 shadow-2xl relative overflow-hidden">
        <!-- Barra superior amarela -->
        <div class="absolute top-0 left-0 w-full h-1 bg-yellow-500"></div>

        <!-- Estado de sucesso -->
        <div id="form-contato-success" style="display:none" class="text-center py-8">
          <h3 class="text-2xl font-bold font-industrial text-white uppercase mb-3">Recebido.</h3>
          <p class="text-gray-400">Te chamo no WhatsApp em breve.</p>
        </div>

        <form id="form-contato" onsubmit="handleContatoSubmit(event)">
          <!-- Estado de erro -->
          <p id="form-contato-error" style="display:none" class="text-red-500 text-sm mb-4 text-center">Erro ao enviar. Tente novamente.</p>

          <!-- ===== CAMPOS OCULTOS PADRAO GTM ===== -->
          <TrackingHiddenFields />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="contato-nome" class="block text-white text-xs font-bold mb-2 font-industrial uppercase tracking-widest">Nome</label>
              <input id="contato-nome" type="text" name="name" required class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3.5 focus:border-yellow-500 focus:outline-none transition-colors placeholder-gray-700" placeholder="Como te chamar">
            </div>
            <div>
              <label for="contato-empresa" class="block text-white text-xs font-bold mb-2 font-industrial uppercase tracking-widest">Empresa</label>
              <input id="contato-empresa" type="text" name="company" class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3.5 focus:border-yellow-500 focus:outline-none transition-colors placeholder-gray-700" placeholder="Onde você atua">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="contato-whatsapp" class="block text-white text-xs font-bold mb-2 font-industrial uppercase tracking-widest">WhatsApp</label>
              <input id="contato-whatsapp" type="tel" name="whatsapp" required class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3.5 focus:border-yellow-500 focus:outline-none transition-colors placeholder-gray-700" placeholder="+55 11 90000-0000">
            </div>
