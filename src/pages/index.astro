              <input id="contato-email" type="email" name="email" required class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3.5 focus:border-yellow-500 focus:outline-none transition-colors placeholder-gray-700" placeholder="seu@email.com">
            </div>
          </div>

          <div class="mb-8">
            <label for="contato-mensagem" class="block text-white text-xs font-bold mb-2 font-industrial uppercase tracking-widest">Como posso ajudar? <span class="text-gray-600 font-normal lowercase tracking-normal">(opcional)</span></label>
            <textarea id="contato-mensagem" name="message" rows="4" class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3.5 focus:border-yellow-500 focus:outline-none transition-colors placeholder-gray-700 resize-none" placeholder="Escreva à vontade. Ou só mande oi e a gente conversa."></textarea>
          </div>

          <button type="submit" class="w-full bg-yellow-500 hover:bg-yellow-400 text-black font-bold uppercase tracking-widest py-4 text-sm md:text-base transition-all flex items-center justify-center gap-2 group">
            <span class="contato-btn-label">Enviar contato</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </button>

          <p class="flex items-center justify-center gap-2 text-xs text-gray-600 mt-4">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
            Suas informações são confidenciais.
          </p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
  function handleContatoSubmit(e) {
    e.preventDefault();
    var form = e.target;
    var btn = form.querySelector('button[type="submit"]');
    var btnLabel = btn.querySelector('.contato-btn-label');
    var originalLabel = btnLabel ? btnLabel.textContent : '';
    btn.disabled = true;
    if (btnLabel) btnLabel.textContent = 'Enviando...';

    if (window.__wlPopulateHiddenFields) window.__wlPopulateHiddenFields(form);
    var tracking = window.__wlTracking || {};
    var formData = new FormData(form);
    var payload = {};
    formData.forEach(function(value, key) { payload[key] = value; });
    Object.keys(tracking).forEach(function(k) { payload[k] = tracking[k]; });

    if (window.__wlPushLeadSubmit) {
      window.__wlPushLeadSubmit({
        name: payload.name,
        email: payload.email,
        whatsapp: payload.whatsapp
      });
    }

    payload.source = "tocha_home_contato";

    fetch("https://apolo-lead-proxy.rapricardo.workers.dev", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload)
    }).then(function() {
      var successDiv = document.getElementById('form-contato-success');
      if (successDiv) successDiv.style.display = 'block';
      form.style.display = 'none';
    }).catch(function() {
      btn.disabled = false;
      if (btnLabel) btnLabel.textContent = originalLabel;
      var errorMsg = document.getElementById('form-contato-error');
      if (errorMsg) errorMsg.style.display = 'block';
    });
  }
  </script>

