---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import VideoPlayer from '../../../components/membros/VideoPlayer';
import { getLessonBySlug, getNextLesson } from '../../../lib/lessons';
import { getUserAccess, hasAccess } from '../../../lib/auth';

const { slug } = Astro.params;

if (!slug) {
  return new Response('Aula não encontrada', { status: 404 });
}

const lesson = await getLessonBySlug(slug);

if (!lesson) {
  return new Response('Aula não encontrada', { status: 404 });
}

const session = Astro.locals.session!;

// Acesso: se não é gratuito, checa se o usuário tem o produto liberado
let accessList: string[] = Astro.locals.accessSlugs ?? [];
if (!lesson.is_free) {
  if (!Astro.locals.accessSlugs) {
    accessList = await getUserAccess(session.user.id);
  }
  if (!hasAccess(accessList, lesson.product_slug)) {
    return Astro.redirect('/membros/?acesso=bloqueado');
  }
}

// Próxima aula (opcional)
const nextLesson = await getNextLesson(lesson.product_slug, lesson.order_index);

// Se o usuário ainda não tem acesso ao produto da próxima aula (e ela não é gratuita),
// o botão "Próximo" aponta para a oferta em vez da aula
let nextHref: string | null = null;
let nextLabel: string | null = null;
if (nextLesson) {
  const nextRequiresPayment = !nextLesson.is_free;
  const hasNextAccess = hasAccess(accessList, nextLesson.product_slug);
  if (nextRequiresPayment && !hasNextAccess) {
    nextHref = '/video-ia/oferta/';
    nextLabel = `Próximo: ${nextLesson.title} (desbloquear)`;
  } else {
    nextHref = `/membros/aulas/${nextLesson.slug}/`;
    nextLabel = `Próximo: ${nextLesson.title}`;
  }
}

// Parágrafos do resumo (split em linhas em branco)
const paragraphs = (lesson.summary_md ?? '')
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter((p) => p.length > 0);
---

<Layout title={lesson.title} description={lesson.description ?? undefined}>
  <section class="py-20 px-6 min-h-screen">
    <div class="max-w-3xl mx-auto">
      <a
        href="/membros/"
        class="text-xs font-mono text-gray-600 hover:text-yellow-500 uppercase tracking-wider transition-colors mb-8 inline-block"
      >
        &larr; Voltar ao painel
      </a>

      <h1 class="text-3xl font-bold font-industrial text-white uppercase mb-2">
        {lesson.title}
      </h1>

      {
        lesson.is_free ? (
          <p class="text-gray-500 text-sm mb-8 font-mono">CONTEUDO GRATUITO</p>
        ) : (
          <span class="inline-block text-xs font-mono text-yellow-500 border border-yellow-500/30 bg-yellow-500/10 px-3 py-1 mb-4">
            CONTEUDO PAGO
          </span>
        )
      }

      {
        (lesson.type === 'video' || lesson.type === 'live_replay') && lesson.content_ref && (
          <div class="mt-4">
            <VideoPlayer
              videoId={lesson.content_ref}
              lessonSlug={lesson.slug}
              isLoggedIn={true}
              client:load
            />
          </div>
        )
      }

      {
        lesson.type === 'download' && (
          <div class="mt-8 border border-gray-800 bg-gray-900/50 p-8">
            <div class="flex items-start gap-6">
              <div class="shrink-0">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-12 h-12 text-yellow-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"
                  />
                </svg>
              </div>
              <div>
                <h2 class="text-xl font-bold font-industrial text-white uppercase mb-2">
                  {lesson.title}
                </h2>
                {lesson.description && (
                  <p class="text-gray-400 text-sm leading-relaxed mb-6">
                    {lesson.description}
                  </p>
                )}
                <form method="POST" action="/api/download">
                  <input type="hidden" name="productSlug" value={lesson.product_slug} />
                  <button
                    type="submit"
                    class="inline-block bg-yellow-500 hover:bg-yellow-400 text-black font-bold uppercase tracking-widest px-8 py-4 text-sm transition-all cursor-pointer"
                    style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);"
                  >
                    Baixar &darr;
                  </button>
                </form>
              </div>
            </div>
          </div>
        )
      }

      {
        paragraphs.length > 0 && (
          <div class="mt-12 space-y-6 text-gray-400 leading-relaxed">
            {paragraphs.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        )
      }

      {
        nextHref && nextLabel && (
          <div class="mt-12 border-t border-gray-800 pt-8">
            <a
              href={nextHref}
              class="inline-block bg-yellow-500 hover:bg-yellow-400 text-black font-bold uppercase tracking-widest px-8 py-4 text-sm transition-all"
            >
              {nextLabel} &rarr;
            </a>
          </div>
        )
      }
    </div>
  </section>
</Layout>
